QWidget {
    background: #f8fafc;
    color: #111827;
    font-family: "Segoe UI", Arial;
    font-size: 10pt;
}

QFrame#header,
QFrame#sidebar,
QFrame#statusBar,
QFrame#card {
    background: #ffffff;
    border: 1px solid rgba(128, 128, 128, 0.22);
}

QPushButton {
    background: #ffffff;
    border: 1px solid rgba(128, 128, 128, 0.45);
    border-radius: 6px;
    padding: 8px 10px;
}
